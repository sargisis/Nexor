{
  "name": "msv-language",
  "displayName": "MSV Language",
  "description": "MSV programming language support — syntax highlighting, snippets, and language configuration",
  "version": "0.1.0",
  "publisher": "msv",
  "license": "MIT",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "msv",
    "language",
    "syntax highlighting",
    "snippets"
  ],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/msv-lang/msv-vscode"
  },
  "contributes": {
    "languages": [
      {
        "id": "msv",
        "aliases": [
          "MSV",
          "msv"
        ],
        "extensions": [
          ".msv"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "msv",
        "scopeName": "source.msv",
        "path": "./syntaxes/msv.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "msv",
        "path": "./snippets/msv.json"
      }
    ]
  }
}
