{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MSV",
  "scopeName": "source.msv",
  "fileTypes": ["msv"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#definitions" },
    { "include": "#keywords" },
    { "include": "#language-vars" },
    { "include": "#types" },
    { "include": "#function-calls" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.number-sign.msv",
      "match": "#.*$"
    },
    "strings": {
      "name": "string.quoted.double.msv",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.msv",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.msv",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    "definitions": {
      "patterns": [
        {
          "match": "\\b(action)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "keyword.declaration.function.msv" },
            "2": { "name": "entity.name.function.msv" }
          }
        },
        {
          "match": "\\b(class)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.type.msv" },
            "2": { "name": "entity.name.type.class.msv" }
          }
        },
        {
          "match": "\\b(protocol)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.type.msv" },
            "2": { "name": "entity.name.type.protocol.msv" }
          }
        },
        {
          "match": "\\b(extend)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.msv" },
            "2": { "name": "entity.name.type.class.msv" }
          }
        },
        {
          "match": "\\b(adopt)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.msv" },
            "2": { "name": "entity.name.type.protocol.msv" }
          }
        },
        {
          "match": "\\b(hook)\\s+(before|after)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.msv" },
            "2": { "name": "entity.name.function.modifier.msv" },
            "3": { "name": "entity.name.function.msv" }
          }
        },
        {
          "match": "\\b(computed)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.msv" },
            "2": { "name": "variable.other.property.msv" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(return|break|continue|throw)\\b",
          "name": "keyword.control.flow.msv"
        },
        {
          "match": "\\b(when|otherwise|switch|case|default)\\b",
          "name": "keyword.control.conditional.msv"
        },
        {
          "match": "\\b(wloop|floop)\\b",
          "name": "keyword.control.loop.msv"
        },
        {
          "match": "\\b(try|catch)\\b",
          "name": "keyword.control.exception.msv"
        },
        {
          "match": "\\b(test|assert)\\b",
          "name": "keyword.other.test.msv"
        },
        {
          "match": "\\b(paint|new)\\b",
          "name": "keyword.other.msv"
        },
        {
          "match": "\\b(true|false|null)\\b",
          "name": "constant.language.msv"
        }
      ]
    },
    "language-vars": {
      "match": "\\b(this|super)\\b",
      "name": "variable.language.msv"
    },
    "types": {
      "match": "\\b(int|float|bool|string|array|dict)\\b",
      "name": "storage.type.msv"
    },
    "function-calls": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captures": {
        "1": { "name": "support.function.msv" }
      }
    },
    "operators": {
      "name": "keyword.operator.msv",
      "match": "[+\\-*/%<>=!&|]+"
    }
  }
}
